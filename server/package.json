{
  "name": "global-broadcast-backend",
  "version": "1.0.0",
  "description": "Global Radio Broadcast App Backend - Cloudflare Workers + D1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create radio-stations",
    "db:migrate": "wrangler d1 execute radio-stations --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "wrangler": "^4.113.0"
  }
}
